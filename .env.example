# ==================== 环境变量配置模板 ====================
# 复制此文件为 .env.development 或 .env.production 并填入实际值
# ⚠️ 敏感信息（API Key、密码等）切勿提交到代码仓库

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://odi_user:odi_pass_dev@localhost:5432/odi_saas_dev
DATABASE_SYNC_URL=postgresql://odi_user:odi_pass_dev@localhost:5432/odi_saas_dev

# ===== JWT（生产环境必填） =====
# 生产环境: JWT_SECRET_KEY 不能为空，且必须使用随机密钥
# 开发环境: 可留空，系统会自动使用临时密钥（不推荐生产使用）
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== CORS（生产环境禁止 localhost） =====
# 开发环境示例:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# 生产环境示例（禁止包含 localhost / 127.0.0.1）:
# CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# ===== AI 模型 API Keys =====（必需，用于调用 LLM 服务）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
KIMI_API_KEY=sk-your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ===== 企业征信 API =====
QICHACHA_API_KEY=your-qichacha-api-key
TIANYANCHA_API_KEY=your-tianyancha-api-key
BAIDU_CREDIT_API_KEY=your-baidu-credit-api-key
DEFAULT_CORP_INFO_PROVIDER=qichacha

# ===== 应用配置 =====
# 可选值: development | production
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
